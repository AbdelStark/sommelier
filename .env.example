# Copy to .env (git-ignored). Remote entrypoints forward these to Modal
# containers via modal.Secret.from_dotenv; they are never written to
# artifacts, and the redaction scanner keeps them out of logs and reports.

# Hugging Face token with access to the configured base model.
HF_TOKEN=

# Optional: require this value as a Bearer token on the vLLM serving
# endpoint (remote_serving.py). Without it the endpoint is open.
# SOMMELIER_SERVE_API_KEY=

# Optional: wandb key for opt-in experiment tracking.
# WANDB_API_KEY=
